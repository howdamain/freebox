# ── Required ────────────────────────────────────────────────────────────────

# Supabase project URL (e.g. https://xyzxyz.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase SERVICE ROLE key (bypasses RLS — keep secret, never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key_here

# ── Browser / scraping ───────────────────────────────────────────────────────

# Run Chromium in headless mode (true) or headed/visible mode (false).
# Use false for debugging to watch the browser navigate.
# HEADLESS=true

# Optional HTTP or SOCKS5 proxy URL for all Playwright browser contexts.
# Strongly recommended for Facebook scraping to reduce IP-ban risk.
# Residential proxies work best. Format: http://user:pass@host:port
# PROXY_URL=http://user:pass@proxy.example.com:8080

# Number of scroll passes per page to trigger lazy-loaded GraphQL batches.
# Increase if you're missing listings; decrease to speed up runs.
# SCROLL_PASSES=3

# ── Optional tuning ──────────────────────────────────────────────────────────

# Minimum estimated resale value (dollars) for a listing to be kept. Default: 30
# MIN_PROFIT=30

# Maximum listings to fetch per single worker run (across all targets). Default: 500
# MAX_RESULTS_PER_RUN=500

# How many due crawl_targets to pull per pass. Default: 20
# TARGETS_PER_PASS=20
